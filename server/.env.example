PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/spcms?retryWrites=true&w=majority
JWT_ACCESS_SECRET=replace-with-a-strong-secret
JWT_REFRESH_SECRET=replace-with-a-strong-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Notification settings
# Channel used when patient has a phone number: system | sms | whatsapp
NOTIFICATION_DEFAULT_CHANNEL=system
# Set to "true" to enable real SMS delivery via Fast2SMS
SMS_PROVIDER_ENABLED=false
WHATSAPP_PROVIDER_ENABLED=false
# Provider phone numbers (legacy — not needed for Fast2SMS)
SMS_FROM_NUMBER=
WHATSAPP_FROM_NUMBER=

# Fast2SMS — get free API key at https://www.fast2sms.com
FAST2SMS_API_KEY=
